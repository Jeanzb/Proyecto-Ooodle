        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Health responde 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.test('Health devuelve status ok', function () {",
              "  pm.expect(data.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
